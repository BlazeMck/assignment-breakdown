{
  "name": "assignment-breakdown",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "api"
  ],
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run client:start\" \"npm run server:dev\"",
    "client:start": "npm run dev --workspace=client",
    "client:build": "npm run build --workspace=client",
    "client:test": "npm test --workspace=client",
    "server:dev": "npm run dev --workspace=server",
    "server:start": "npm start --workspace=server",
    "server:seed": "npm run seed --workspace=server",
    "server:test": "npm test --workspace=server",
    "test": "npm run test:server",
    "test:client": "npm run client:test",
    "test:server": "npm run server:test",
    "test:watch": "npm run test:watch --workspace=server",
    "build": "npm run client:build",
    "build:api": "echo 'Vercel serverless functions ready'"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.1.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "react-big-calendar": "^1.20.0"
  }
}
